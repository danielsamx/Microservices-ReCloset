# ============================================================
# ReCloset - Root environment file (copy to .env)
# NEVER commit the real .env. Secrets live here only for local dev.
# ============================================================

# ---- Shared ----
APP_ENV=local
APP_DEBUG=true
LOG_LEVEL=info
LOG_CHANNEL=stderr            # structured JSON logs to stdout for Prometheus/Docker

# ---- Gateway ----
GATEWAY_PORT=8080

# ---- Frontend ----
FRONTEND_PORT=5173
VITE_API_URL=http://localhost:8080/api
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
VITE_REVERB_APP_KEY=recloset-key

# ---- Auth Service ----
AUTH_APP_KEY=base64:REPLACE_WITH_php_artisan_key_generate_AUTH
AUTH_DB_DATABASE=recloset_auth
AUTH_DB_USERNAME=recloset
AUTH_DB_PASSWORD=change_me_auth

# ---- Item Service ----
ITEM_APP_KEY=base64:REPLACE_WITH_php_artisan_key_generate_ITEM
ITEM_DB_DATABASE=recloset_items
ITEM_DB_USERNAME=recloset
ITEM_DB_PASSWORD=change_me_item

# ---- Chat Service ----
CHAT_APP_KEY=base64:REPLACE_WITH_php_artisan_key_generate_CHAT
CHAT_DB_DATABASE=recloset_chat
CHAT_DB_USERNAME=recloset
CHAT_DB_PASSWORD=change_me_chat

# ---- Media Service ----
MEDIA_APP_KEY=base64:REPLACE_WITH_php_artisan_key_generate_MEDIA
MEDIA_DB_DATABASE=recloset_media
MEDIA_DB_USERNAME=recloset
MEDIA_DB_PASSWORD=change_me_media
MEDIA_MAX_FILE_SIZE=52428800   # 50 MB

# ---- Reverb (WebSocket server) ----
REVERB_APP_ID=recloset
REVERB_APP_KEY=recloset-key
REVERB_APP_SECRET=change_me_reverb_secret

# ---- Inter-service token used by services to introspect Sanctum tokens ----
INTERNAL_SERVICE_TOKEN=change_me_internal_service_token
